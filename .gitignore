# Python sanal ortamı
.venv/

# Python geçici dosyaları
__pycache__/
*.py[cod]

# Gizli ortam değişkenleri
.env

# Jupyter geçici dosyaları
.ipynb_checkpoints/

# Editör ayarları
.vscode/
.idea/

# Ham veri dosyaları
data/raw/*
!data/raw/.gitkeep

# İşlenmiş veri dosyaları
data/processed/*
!data/processed/.gitkeep

# Kişisel staj günlüğü
docs/staj-gunlugu.md

# SQLite veri tabanı dosyaları
data/database/*.db
data/database/*.db-shm
data/database/*.db-wal
data/database/*.db-journal

# Klasör yapısının Git'te korunması
!data/database/.gitkeep
@'

# İlçe bazlı otomatik üretilen kontrol raporları
frontend/*_aday_bolge_degerlendirmesi.html
frontend/*_aday_bolge_degerlendirme_haritasi.html
frontend/*_pilot_uydu_alanlari.html
frontend/*_sentinel2_rgb.html
frontend/*_worldcover_*_aday_alanlari.html

# Otomatik üretilen Sentinel-2 önizleme görselleri
frontend/assets/sentinel2/**/*.png
'@ | Add-Content .gitignore